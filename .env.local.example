# GitHub AI Token (Recommended - Free for lyrics generation)
GITHUB_TOKEN=your_github_token_here

# OpenAI API Key (Optional - Fallback for lyrics generation)
OPENAI_API_KEY=your_openai_api_key_here

# ElevenLabs API Key (Optional - For real music generation with vocals)
# Get your key from: https://elevenlabs.io
# Without this, the app uses demo instrumental music
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
